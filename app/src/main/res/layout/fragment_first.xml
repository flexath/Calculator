<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:background="?attr/colorPrimary"
                android:minHeight="?attr/actionBarSize"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/audiowide"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="20dp"
                android:textSize="25sp"
                android:textColor="@color/black"
                android:text="@string/calculator_action_title"/>

            <!--            <ImageButton-->
            <!--                android:layout_width="30dp"-->
            <!--                android:layout_height="30dp"-->
            <!--                android:src="@drawable/dots"-->
            <!--                android:background="@color/white"-->
            <!--                android:scaleType="fitCenter"-->
            <!--                android:layout_margin="10dp"-->
            <!--                app:layout_constraintTop_toTopOf="parent"-->
            <!--                app:layout_constraintBottom_toBottomOf="parent"-->
            <!--                app:layout_constraintEnd_toEndOf="parent"/>-->


        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/txtLinearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/calculatorLinearLayout">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtOperation"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="3"
                android:padding="10dp"
                android:textIsSelectable="true"
                android:cursorVisible="true"
                android:lines="3"
                android:maxLines="3"
                android:gravity="end"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="30sp"
                android:autoSizeMaxTextSize="30sp"
                android:autoSizeMinTextSize="20sp"/>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/txtResult"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingEnd="10dp"
                android:paddingStart="10dp"
                android:lines="1"
                android:maxLines="1"
                android:gravity="end"
                android:text="Answer is here"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="25sp"
                android:autoSizeMaxTextSize="25sp"
                android:autoSizeMinTextSize="15sp"/>

            <View
                android:id="@+id/divider"
                android:layout_width="370dp"
                android:layout_height="1dp"
                android:layout_marginTop="15dp"
                android:layout_gravity="center"
                android:background="?android:attr/listDivider" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/calculatorLinearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:layout_margin="5dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnClear"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/copyright" />

                <ImageButton
                    android:id="@+id/btnBackSpace"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/backspace" />

                <ImageButton
                    android:id="@+id/btnPercent"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/percentage" />

                <ImageButton
                    android:id="@+id/btnDivide"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/divide" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnSeven"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/seven" />

                <ImageButton
                    android:id="@+id/btnEight"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/eight" />

                <ImageButton
                    android:id="@+id/btnNine"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/nine" />

                <ImageButton
                    android:id="@+id/btnCross"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/xmark" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnFour"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/four" />

                <ImageButton
                    android:id="@+id/btnFive"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/five" />

                <ImageButton
                    android:id="@+id/btnSix"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/six" />

                <ImageButton
                    android:id="@+id/btnMinus"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/minus" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnOne"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/one" />

                <ImageButton
                    android:id="@+id/btnTwo"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/two" />

                <ImageButton
                    android:id="@+id/btnThree"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/three" />

                <ImageButton
                    android:id="@+id/btnPlus"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/add" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnBox"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/rotation" />

                <ImageButton
                    android:id="@+id/btnZero"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/zero" />

                <ImageButton
                    android:id="@+id/btnDot"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/dot" />

                <ImageButton
                    android:id="@+id/btnEqual"
                    style="@style/buttonOperatorStyle"
                    android:src="@drawable/equal" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
